# FINLIT — environment variable reference.
# Copy the relevant block into backend/.env and frontend/.env (both gitignored).
# On Vercel, add these under each service's Environment Variables.

# ───────────────────────── backend/.env ─────────────────────────
PORT=3001
# Local: http://localhost:3000 · Prod: your deployed Vercel URL (used for CORS whitelist)
FRONTEND_URL=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
# Service-role key — BACKEND ONLY, never expose to the browser
SUPABASE_SERVICE_KEY=your_service_role_key
GROQ_API_KEY=your_groq_key
GIPHY_API_KEY=your_giphy_key

# ──────────────────────── frontend/.env ─────────────────────────
# Local dev:                      http://localhost:3001/api
# Vercel (multi-service vercel.json): /_/backend/api
REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your_anon_key
# Optional error reporting — leave blank to disable
REACT_APP_SENTRY_DSN=
